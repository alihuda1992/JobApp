# Supabase project — optional if ../.env.local has VITE_SUPABASE_URL / VITE_SUPABASE_ANON_KEY
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# The Job App account the MCP server signs in as (RLS applies as this user)
JOBAPP_EMAIL=you@example.com
JOBAPP_PASSWORD=your-password
